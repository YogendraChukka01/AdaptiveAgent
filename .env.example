# Backend configuration
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=BAAI/bge-m3

RERANKER_PROVIDER=bge

VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./chroma_data

DATABASE_URL=postgresql+asyncpg://safeagent:safeagent@localhost:5432/safeagent
DATABASE_URL_SYNC=postgresql://safeagent:safeagent@localhost:5432/safeagent
REDIS_URL=redis://localhost:6379/0

MAX_STEPS=10
CONFIDENCE_RETRY_THRESHOLD=30.0
EVIDENCE_THRESHOLD=0.3
EVIDENCE_MIN_COVERAGE=0.5
HIGH_RISK_THRESHOLD=70.0

EVAL_ENABLED=true
EVAL_THRESHOLD=0.85

API_KEY=

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=safeagent

CORS_ORIGINS=["http://localhost:3000"]

# Cloud fallback (optional)
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_FALLBACK_API_KEY=sk-...
# LLM_FALLBACK_PROVIDER=openai

# Memory distillation
MEMORY_DISTILL_ENABLED=true
